# Discord
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here
DISCORD_GUILD_ID=your_dev_server_id_here   # only for dev command registration

# FCE API
FCE_API_BASE=https://api2.freecustom.email/v1
FCE_CLI_AUTH_URL=https://www.freecustom.email/api/cli-auth
FCE_SITE_URL=https://www.freecustom.email
FCE_CONTACT_API=https://www.freecustom.email/api/contact

# Bot public URL (your server, nginx-proxied)
CALLBACK_BASE_URL=https://bot.freecustom.email
CALLBACK_PORT=4242

# Admin notifications
ADMIN_EMAIL=dishupandey57@gmail.com

# Shared admin password (same value as fce-frontend ADMIN_PASSWORD env var)
ADMIN_PASSWORD=change_me_strong_secret

# Database (reuse existing Postgres instance)
DATABASE_URL=postgresql://user:password@postgres:5432/fce_discord_bot

# Redis (reuse existing Redis container)
REDIS_URL=redis://redis:6379

# Login state token TTL in seconds
LOGIN_STATE_TTL=180

# Feedback: trigger after this many commands
FEEDBACK_TRIGGER_COUNT=15
