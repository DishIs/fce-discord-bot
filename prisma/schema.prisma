generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  discordId    String   @id
  username     String
  apiKey       String
  plan         String   @default("free")
  planLabel    String   @default("Free")
  commandCount Int      @default(0)
  feedbackSent Boolean  @default(false)
  jsonMode     Boolean  @default(false)
  locale       String   @default("en-US")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  watches      Watch[]
  feedback     Feedback[]
}

model Watch {
  id        String   @id @default(cuid())
  discordId String
  inbox     String
  channelId String
  guildId   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [discordId], references: [discordId], onDelete: Cascade)

  @@unique([discordId, inbox])
  @@index([active])
}

model Feedback {
  id           String   @id @default(cuid())
  discordId    String
  username     String
  stars        Int
  comment      String?
  commandCount Int
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [discordId], references: [discordId], onDelete: Cascade)
}

model LoginState {
  state     String   @id
  discordId String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([discordId])
}
